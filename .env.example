# PostgreSQL connection string from Neon/Supabase.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL=""

# Private one-time/admin token used for /api/db/migrate and /api/db/seed.
# Set the same value in Vercel Environment Variables, then send it with x-setup-token.
ADMIN_SETUP_TOKEN=""

# Keep empty for Neon/Supabase. Use "disable" only for a local PostgreSQL without SSL.
PGSSLMODE=""

# Lark SSO / permission gate.
# Keep AUTH_REQUIRED empty/false until Lark Developer Console is configured.
AUTH_REQUIRED="false"
AUTH_SESSION_SECRET=""
APP_BASE_URL="https://your-vercel-domain.vercel.app"
LARK_APP_ID=""
LARK_APP_SECRET=""
LARK_REDIRECT_URI="https://your-vercel-domain.vercel.app/api/auth/lark/callback"
LARK_OPEN_BASE_URL="https://open.larksuite.com"
LARK_AUTHORIZE_URL="https://accounts.larksuite.com/open-apis/authen/v1/authorize"
LARK_AUTH_SCOPE=""
LARK_AUTO_PROVISION="false"
